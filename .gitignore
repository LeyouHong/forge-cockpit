# Generated by Cargo
# will have compiled files and executables
debug/
target/
jobs/**


# These are backup files generated by rustfmt
**/*.rs.bk
.idea
# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
.aider*
.env
.DS_Store
# Database files
*.db
*.db-*
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Backup files
*.bak
*.rs.bak
.tasks
*.new
.vscode/
.fastembed_cache/
*.log*
*-dump.json
*-dump.html
.mcp.json
*.d.ts
*.js
*.map
# vendored web assets are source, not build output
!crates/forge_web/src/vendor/*.js
# the npm wrapper package is hand-written source, not build output — without
# these, a new file here is silently left out of the commit and ships broken
!npm/forge-cockpit/*.js
!npm/forge-cockpit/bin/*.js
**/.forge/request.body.json
# Pipeline/team runtime state (pipelines are now global under ~/.forge-web)
**/.forge/pipelines/
.forge-workspace/
node_modules/
bench/__pycache__
scripts/__pycache__/
.codebase-memory/
.ai/

# Local generated docs (not committed)
forge-framework-guide.pdf

# npm packaging build output
npm/dist/
npm/**/node_modules/
multiagent-orchestration-guide.pdf
